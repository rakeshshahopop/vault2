rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only signed-in users (i.e. accounts you created in Firebase Auth) can
    // read or write anything. There is no public/anonymous access at all.
    match /folders/{folderId} {
      allow read, write: if request.auth != null;
    }

    match /files/{fileId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
